# Copy this file to .env and fill in real values for local development.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Supabase Postgres connection string. Supabase Project Settings -> Database
# -> Connection string. On Railway, prefer the "Transaction" pooler URI
# (port 6543, pgbouncer) since Railway containers are short-lived/scale-to-zero.
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# --- CORS ---
# Comma-separated list of frontend origins (Vercel URL(s) in production).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Supabase (for validating frontend-issued JWTs) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase Storage (S3-compatible, for the Documents domain) ---
# Project Settings -> Storage -> S3 Connection. Separate credentials from
# SUPABASE_SERVICE_ROLE_KEY above.
SUPABASE_STORAGE_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=us-east-1

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASE_PLAN=
STRIPE_PRICE_TIME_TRACKING_ADDON=
STRIPE_PRICE_LOYALTY_ADDON=
STRIPE_PRICE_RESERVATIONS_ADDON=

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
